:root {
  --bg-primary: #f4f7fb;
  --bg-secondary: #ffffff;

  --text-primary: #111827;
  --text-secondary: #6b7280;

  --border-color: #e5e7eb;

  --accent: #4f46e5;
  --accent-hover: #4338ca;
}

[data-theme='dark'] {
  --bg-primary: #0f172a;
  --bg-secondary: #111827;

  --text-primary: #f8fafc;
  --text-secondary: #94a3b8;

  --border-color: #1f2937;

  --accent: #6366f1;
  --accent-hover: #818cf8;
}